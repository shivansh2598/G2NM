# .env.example — copy to .env and fill in your values
USER_ID=your-name-here
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Embedding model: bge-small-en (local, free) or text-embedding-3-small (OpenAI)
EMBEDDING_MODEL=bge-small-en

# Only needed if using OpenAI embeddings
# OPENAI_API_KEY=sk-your-openai-key

# Only needed if using hosted ChromaDB (Option C)
# CHROMA_HOST=https://your-chroma-instance.com
# CHROMA_API_KEY=your-chroma-key
